/* 石室书院风全局样式 */
page {
  background: #f6f1e7;
  color: #2a2320;
  font-size: 30rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fffdf8;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 56, 30, 0.06);
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #a4232a;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
}
.btn-primary::after { border: none; }

.btn-ghost {
  background: #f0eadd;
  color: #6b6156;
  border-radius: 12rpx;
}
.btn-ghost::after { border: none; }

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #fff;
}
.tag-待处理 { background: #d48806; }
.tag-处理中 { background: #1d6fb8; }
.tag-已解决 { background: #2f9e44; }
.tag-已关闭 { background: #8c8c8c; }
.tag-已取消 { background: #c07a12; }

.tag-urgent { background: #c0392b; }

.muted { color: #8a7f72; font-size: 26rpx; }
.title-serif { font-weight: 700; color: #7a1519; }
.hr { height: 1rpx; background: #ece4d5; margin: 20rpx 0; }
