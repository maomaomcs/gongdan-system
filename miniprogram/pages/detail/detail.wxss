.head { display: flex; justify-content: space-between; align-items: flex-start; }
.d-title { font-size: 36rpx; font-weight: 700; color: #2a2320; flex: 1; margin-right: 16rpx; }
.code { margin-top: 10rpx; }

.kv { display: flex; margin: 14rpx 0; }
.k { width: 150rpx; color: #8a7f72; font-size: 28rpx; flex-shrink: 0; }
.v { flex: 1; color: #2a2320; font-size: 28rpx; }

.imgs { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 14rpx; }
.img { width: 200rpx; height: 200rpx; border-radius: 12rpx; }

.log { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.log-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #a4232a; margin-top: 10rpx; flex-shrink: 0; }
.log-body { flex: 1; }
.log-content { font-size: 28rpx; color: #3a332c; }
.log-meta { margin-top: 6rpx; }

.actions { display: flex; gap: 20rpx; margin-top: 10rpx; }
.act { flex: 1; }
