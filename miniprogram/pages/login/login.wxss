.login-wrap { padding: 60rpx 40rpx; }
.brand { display: flex; align-items: center; gap: 20rpx; margin: 40rpx 0 50rpx; }
.seal {
  width: 96rpx; height: 96rpx; border-radius: 16rpx;
  background: #a4232a; border: 3rpx solid #b8863b; color: #f6f1e7;
  font-size: 56rpx; font-weight: 700; text-align: center; line-height: 96rpx;
}
.brand-cn { font-size: 40rpx; font-weight: 700; color: #7a1519; }
.brand-en { font-size: 24rpx; color: #a89e91; margin-top: 6rpx; }

.tabs { display: flex; margin-bottom: 30rpx; border-bottom: 2rpx solid #eee2cf; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; color: #8a7f72; font-size: 32rpx; }
.tab.on { color: #a4232a; font-weight: 700; border-bottom: 4rpx solid #a4232a; }

.ipt {
  background: #f8f4ec; border: 2rpx solid #eee2cf; border-radius: 12rpx;
  padding: 24rpx; margin-bottom: 22rpx; font-size: 30rpx;
}
.submit { margin-top: 10rpx; }
.tip { text-align: center; margin-top: 24rpx; }
